# ── bat config — cat replacement with syntax highlighting ──────────
--theme="Monokai Extended"
--style="numbers,changes,header"
--italic-text=always
--wrap=never
--paging=auto

# Use `bat` as the manpage highlighter (zshrc adds the env var)
--map-syntax="*.env*:DotENV"
--map-syntax=".ignore:Git Ignore"
--map-syntax=".env*:DotENV"
--map-syntax="mise.toml:TOML"
--map-syntax="*.justfile:Makefile"
--map-syntax="Justfile:Makefile"
--map-syntax="justfile:Makefile"
